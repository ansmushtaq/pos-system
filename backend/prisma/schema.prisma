generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  CASHIER
  VIEWER
}

enum ShopType {
  GENERAL
  GROCERY
  PHARMACY
  REPAIR_SHOP
  ENGINE_OIL
}

enum Unit {
  PCS
  KG
  G
  LITER
  ML
  BOX
  PACK
  SET
  BOTTLE
  STRIP
  TABLET
  SERVICE
}

enum PaymentMethod {
  CASH
  CREDIT
  SEMI_CREDIT
  CARD
}

enum SaleStatus {
  COMPLETED
  VOIDED
}

enum MovementType {
  SALE
  SALE_VOID
  PURCHASE
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  RETURN_TO_VENDOR
  RETURN_FROM_CUSTOMER
  OPENING_STOCK
}

enum StockReferenceModel {
  SaleOrder
  PurchaseOrder
}

enum POStatus {
  DRAFT
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum PasscodeModule {
  PROFIT_VIEW
  STOCK_ENTRY
  STOCK_UPDATE
  END_OF_DAY
  PRICE_OVERRIDE
}

enum CreditTransactionType {
  ISSUED
  PAID
  ADJUSTED
  VOID_REVERSAL
}

// ─── AppSettings (singleton — id is always "settings") ───────────────────

model AppSettings {
  id                      String     @id @default("settings")
  shopName                String     @default("My Shop")
  shopType                ShopType   @default(GENERAL)
  address                 String?
  phone                   String?
  email                   String?
  logoUrl                 String?
  receiptHeader           String?
  receiptFooter           String     @default("Thank you for your business!")
  showProfitOnReceipt     Boolean    @default(false)
  currencySymbol          String     @default("Rs.")
  taxLabel                String     @default("Tax")
  defaultTaxPercent       Float      @default(0)
  enableExpiryTracking    Boolean    @default(false)
  enablePrescriptionField Boolean    @default(false)
  enableServiceItems      Boolean    @default(false)
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt

  passcodes               Passcode[]
}

// ─── Passcode ─────────────────────────────────────────────────────────────

model Passcode {
  id            Int            @id @default(autoincrement())
  module        PasscodeModule @unique
  hash          String
  isEnabled     Boolean        @default(true)
  appSettingsId String          @default("settings")
  appSettings   AppSettings     @relation(fields: [appSettingsId], references: [id])
  updatedById   Int?
  updatedBy     User?          @relation("PasscodeUpdatedBy", fields: [updatedById], references: [id])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// ─── Counter (for atomic invoice and PO number generation) ────────────────

model Counter {
  name  String @id
  value Int    @default(0)
}

// ─── ShiftRecord ───────────────────────────────────────────────────────────

model ShiftRecord {
  id                Int       @id @default(autoincrement())
  startedAt         DateTime
  endedAt           DateTime?
  totalSales        Float     @default(0)
  totalTransactions Int       @default(0)
  createdAt         DateTime  @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  @@index([userId, startedAt(sort: Desc)])
}

// ─── User ─────────────────────────────────────────────────────────────────

model User {
  id                Int       @id @default(autoincrement())
  fullName          String
  username          String    @unique
  passwordHash      String
  role              Role
  phone             String?
  isActive          Boolean   @default(true)
  currentShiftStart DateTime?
  lastLoginAt       DateTime?
  isDeleted         Boolean   @default(false)
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  createdById  Int?
  createdBy    User?  @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers User[] @relation("UserCreatedBy")

  deletedById  Int?
  deletedBy    User?  @relation("UserDeletedBy", fields: [deletedById], references: [id])
  deletedUsers User[] @relation("UserDeletedBy")

  updatedPasscodes      Passcode[]            @relation("PasscodeUpdatedBy")
  createdProducts       Product[]             @relation("ProductCreatedBy")
  updatedProducts       Product[]             @relation("ProductUpdatedBy")
  deletedProducts       Product[]             @relation("ProductDeletedBy")
  priceHistoryChanges   ProductPriceHistory[]
  sellerSales           SaleOrder[]           @relation("SaleOrderSeller")
  voidedSales           SaleOrder[]           @relation("SaleOrderVoidedBy")
  priceOverrides        SaleOrderItem[]       @relation("SaleItemOverriddenBy")
  stockMovements        StockMovement[]
  createdVendors        Vendor[]              @relation("VendorCreatedBy")
  updatedVendors        Vendor[]              @relation("VendorUpdatedBy")
  deletedVendors        Vendor[]              @relation("VendorDeletedBy")
  createdPurchaseOrders PurchaseOrder[]       @relation("POCreatedBy")
  updatedPurchaseOrders PurchaseOrder[]       @relation("POUpdatedBy")
  deletedPurchaseOrders PurchaseOrder[]       @relation("PODeletedBy")
  createdCustomers      Customer[]
  updatedCustomers      Customer[]            @relation("CustomerUpdatedBy")
  deletedCustomers      Customer[]            @relation("CustomerDeletedBy")
  deletedCategories     Category[]            @relation("CategoryDeletedBy")
  eodSummaries          EndOfDaySummary[]
  shiftRecords          ShiftRecord[]
  creditTransactions    CreditTransaction[]

  @@index([username])
  @@index([role, isActive, isDeleted])
}

// ─── Category ─────────────────────────────────────────────────────────────

model Category {
  id               Int        @id @default(autoincrement())
  name             String
  isActive         Boolean    @default(true)
  isDeleted        Boolean    @default(false)
  deletedAt        DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  parentCategoryId Int?
  parentCategory   Category?  @relation("CategoryParent", fields: [parentCategoryId], references: [id])
  subCategories    Category[] @relation("CategoryParent")

  deletedById      Int?
  deletedBy        User?      @relation("CategoryDeletedBy", fields: [deletedById], references: [id])

  products         Product[]
}

// ─── Product ──────────────────────────────────────────────────────────────

model Product {
  id                   Int       @id @default(autoincrement())
  name                 String
  sku                  String    @unique
  barcode              String?
  unit                 Unit      @default(PCS)
  purchasePrice        Float
  purchaseTaxPercent   Float     @default(0)
  costPrice            Float
  salePrice            Float
  description          String?
  imageUrl             String?
  expiryTracking       Boolean   @default(false)
  requiresPrescription Boolean   @default(false)
  isService            Boolean   @default(false)
  isActive             Boolean   @default(true)
  isDeleted            Boolean   @default(false)
  deletedAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])

  vendorId    Int?
  vendor      Vendor?  @relation(fields: [vendorId], references: [id])

  createdById Int
  createdBy   User     @relation("ProductCreatedBy", fields: [createdById], references: [id])

  updatedById Int?
  updatedBy   User?    @relation("ProductUpdatedBy", fields: [updatedById], references: [id])

  deletedById Int?
  deletedBy   User?    @relation("ProductDeletedBy", fields: [deletedById], references: [id])

  inventory          Inventory?
  stockMovements     StockMovement[]
  priceHistory       ProductPriceHistory[]
  saleOrderItems     SaleOrderItem[]
  purchaseOrderItems PurchaseOrderItem[]

  @@index([sku])
  @@index([barcode])
  @@index([categoryId, isActive])
  @@index([vendorId])
}

// ─── ProductPriceHistory (APPEND-ONLY — never update or delete) ───────────

model ProductPriceHistory {
  id                    Int      @id @default(autoincrement())
  oldPurchasePrice      Float
  newPurchasePrice      Float
  oldPurchaseTaxPercent Float
  newPurchaseTaxPercent Float
  oldCostPrice          Float
  newCostPrice          Float
  oldSalePrice          Float
  newSalePrice          Float
  changeReason          String?
  effectiveFrom         DateTime @default(now())
  createdAt             DateTime @default(now())

  productId   Int
  product     Product @relation(fields: [productId], references: [id])

  changedById Int
  changedBy   User    @relation(fields: [changedById], references: [id])

  @@index([productId, createdAt(sort: Desc)])
}

// ─── Inventory ────────────────────────────────────────────────────────────

model Inventory {
  id             Int       @id @default(autoincrement())
  quantityOnHand Float     @default(0)
  reorderLevel   Float     @default(0)
  lastMovementAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  productId Int     @unique
  product   Product @relation(fields: [productId], references: [id])

  @@index([quantityOnHand])
}

// ─── StockMovement (ledger — never deleted) ───────────────────────────────

model StockMovement {
  id             Int                  @id @default(autoincrement())
  movementType   MovementType
  quantity       Float
  quantityBefore Float
  quantityAfter  Float
  referenceModel StockReferenceModel?
  referenceId    Int?
  notes          String?
  createdAt      DateTime             @default(now())

  productId     Int
  product       Product @relation(fields: [productId], references: [id])

  performedById Int
  performedBy   User    @relation(fields: [performedById], references: [id])

  @@index([productId, createdAt(sort: Desc)])
  @@index([referenceModel, referenceId])
}

// ─── SaleOrder ────────────────────────────────────────────────────────────

model SaleOrder {
  id             Int           @id @default(autoincrement())
  invoiceNumber  String        @unique
  customerName   String        @default("Walk-in Customer")
  subTotal       Float
  discountAmount Float         @default(0)
  taxAmount      Float         @default(0)
  totalAmount    Float
  totalProfit    Float
  totalCost      Float
  paymentMethod  PaymentMethod
  amountTendered Float         @default(0)
  changeGiven    Float         @default(0)
  amountOnCredit Float         @default(0)
  status         SaleStatus    @default(COMPLETED)
  voidedAt       DateTime?
  voidReason     String?
  offlineId      String?       @unique
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  sellerId   Int
  seller     User      @relation("SaleOrderSeller", fields: [sellerId], references: [id])

  customerId Int?
  customer   Customer? @relation(fields: [customerId], references: [id])

  voidedById Int?
  voidedBy   User?     @relation("SaleOrderVoidedBy", fields: [voidedById], references: [id])

  items      SaleOrderItem[]

  creditTransactions CreditTransaction[]

  @@index([sellerId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([customerId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

// ─── SaleOrderItem ────────────────────────────────────────────────────────

model SaleOrderItem {
  id                  Int      @id @default(autoincrement())
  productName         String
  sku                 String
  quantity            Float
  unitPrice           Float
  costPrice           Float
  originalUnitPrice   Float
  isPriceOverridden   Boolean  @default(false)
  isService           Boolean  @default(false)
  returnedQty         Float    @default(0)
  discount            Float    @default(0)
  totalPrice          Float
  profitAmount        Float
  createdAt           DateTime @default(now())

  saleOrderId Int
  saleOrder   SaleOrder @relation(fields: [saleOrderId], references: [id])

  productId   Int
  product     Product   @relation(fields: [productId], references: [id])

  priceOverriddenById Int?
  priceOverriddenBy   User? @relation("SaleItemOverriddenBy", fields: [priceOverriddenById], references: [id])

  @@index([saleOrderId])
}

// ─── Vendor ───────────────────────────────────────────────────────────────

model Vendor {
  id          Int       @id @default(autoincrement())
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  balance     Float     @default(0)
  isActive    Boolean   @default(true)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdById Int
  createdBy   User  @relation("VendorCreatedBy", fields: [createdById], references: [id])

  updatedById Int?
  updatedBy   User? @relation("VendorUpdatedBy", fields: [updatedById], references: [id])

  deletedById Int?
  deletedBy   User? @relation("VendorDeletedBy", fields: [deletedById], references: [id])

  products       Product[]
  purchaseOrders PurchaseOrder[]
}

// ─── PurchaseOrder ────────────────────────────────────────────────────────

model PurchaseOrder {
  id          Int       @id @default(autoincrement())
  poNumber    String    @unique
  status      POStatus  @default(DRAFT)
  totalAmount Float
  amountPaid  Float     @default(0)
  orderedAt   DateTime?
  receivedAt  DateTime?
  notes       String?
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  vendorId    Int
  vendor      Vendor @relation(fields: [vendorId], references: [id])

  createdById Int
  createdBy   User  @relation("POCreatedBy", fields: [createdById], references: [id])

  updatedById Int?
  updatedBy   User? @relation("POUpdatedBy", fields: [updatedById], references: [id])

  deletedById Int?
  deletedBy   User? @relation("PODeletedBy", fields: [deletedById], references: [id])

  items       PurchaseOrderItem[]

  @@index([vendorId, status])
}

// ─── PurchaseOrderItem ────────────────────────────────────────────────────

model PurchaseOrderItem {
  id          Int      @id @default(autoincrement())
  productName String
  orderedQty  Float
  receivedQty Float    @default(0)
  unitCost    Float
  totalCost   Float
  createdAt   DateTime @default(now())

  purchaseOrderId Int
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  productId   Int
  product     Product @relation(fields: [productId], references: [id])

  @@index([purchaseOrderId])
}

// ─── Customer ─────────────────────────────────────────────────────────────

model Customer {
  id            Int       @id @default(autoincrement())
  name          String
  phone         String?
  email         String?
  address       String?
  creditBalance Float     @default(0)
  totalSpent    Float     @default(0)
  isActive      Boolean   @default(true)
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  createdById Int
  createdBy   User @relation(fields: [createdById], references: [id])

  updatedById Int?
  updatedBy   User? @relation("CustomerUpdatedBy", fields: [updatedById], references: [id])

  deletedById Int?
  deletedBy   User? @relation("CustomerDeletedBy", fields: [deletedById], references: [id])

  saleOrders  SaleOrder[]

  creditTransactions CreditTransaction[]

  @@index([phone])
}

// ─── CreditTransaction ────────────────────────────────────────────────────

model CreditTransaction {
  id            Int                   @id @default(autoincrement())
  type          CreditTransactionType
  amount        Float
  balanceBefore Float
  balanceAfter  Float
  note          String?
  createdAt     DateTime              @default(now())

  customerId  Int
  customer    Customer    @relation(fields: [customerId], references: [id])

  saleOrderId Int?
  saleOrder   SaleOrder?  @relation(fields: [saleOrderId], references: [id])

  createdById Int
  createdBy   User        @relation(fields: [createdById], references: [id])

  @@index([customerId, createdAt(sort: Desc)])
}

// ─── EndOfDaySummary (created once per day, never updated) ───────────────

model EndOfDaySummary {
  id                   Int      @id @default(autoincrement())
  date                 DateTime @unique
  periodStart          DateTime
  periodEnd            DateTime
  totalTransactions    Int      @default(0)
  voidedTransactions   Int      @default(0)
  cashRevenue          Float    @default(0)
  creditRevenue        Float    @default(0)
  semiCreditRevenue    Float    @default(0)
  cardRevenue          Float    @default(0)
  totalRevenue         Float    @default(0)
  totalCost            Float    @default(0)
  totalProfit          Float    @default(0)
  profitMarginPercent  Float    @default(0)
  openingCash          Float    @default(0)
  cashSales            Float    @default(0)
  changeGiven          Float    @default(0)
  expectedClosingCash  Float    @default(0)
  actualClosingCash    Float?
  cashDiscrepancy      Float?
  newCreditIssued      Float    @default(0)
  topProductsByQty     Json     @default("[]")
  topProductsByRevenue Json     @default("[]")
  createdAt            DateTime @default(now())

  generatedById Int
  generatedBy   User @relation(fields: [generatedById], references: [id])

  @@index([date(sort: Desc)])
}
