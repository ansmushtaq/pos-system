NODE_ENV=development
PORT=5000

# Local offline shop
DATABASE_URL="postgresql://postgres:password@localhost:5432/pos_db"

# Cloud (Supabase) — swap this in for web deployment
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

JWT_SECRET=replace_with_long_random_string_minimum_32_characters
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=replace_with_different_long_random_string_minimum_32_characters
REFRESH_TOKEN_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:5173
